  "keyFeatures": [
    "Distributed task queue with PostgreSQL backend",
    "DAG-based workflow orchestration",
    "Durable execution with state persistence",
    "Dynamic concurrency control and rate limiting",
    "Cron scheduling and one-time task scheduling",
    "Event-driven architecture with triggers and listeners",
    "Real-time web dashboard with monitoring and alerting",
    "Multi-language SDKs (TypeScript, Python, Go, Ruby)",
    "Sticky assignment and worker affinity routing",
    "Built-in observability with logs and metrics"
  ],
  "publicApiSurface": [
    "hatchet.task() - Define tasks in Python SDK",
    "hatchet.workflow() - Create workflows in Python SDK",
    "hatchet.task() - Define tasks in TypeScript SDK",
    "hatchet.workflow() - Create workflows in TypeScript SDK",
    "factory.NewTask() - Create tasks in Go SDK",
    "factory.NewWorkflow() - Create workflows in Go SDK",
    "hatchet server start - Start Hatchet server via CLI",
    "hatchet worker start - Start worker process via CLI",
    "/api/v1/stable/tenants/{tenant}/workflow-runs/trigger - Trigger workflow via REST API",
    "/api/v1/stable/workflow-runs/{workflow-run} - Get workflow run details via REST API",
    "/api/v1/stable/tasks/{task} - Get task details via REST API",
    "Dispatcher.Listen - Subscribe to tasks via gRPC",
    "WorkflowService.TriggerWorkflow - Trigger workflows via gRPC",
    "ConcurrencyExpression - Configure concurrency limits",
    "RateLimit - Configure rate limiting",
    "StickyStrategy - Configure worker affinity"
  ]
